{
  "version": 2,
  "name": "afia-company-backend",
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "/index"
    },
    {
      "src": "/api/(.*)",
      "dest": "/index"
    },
    {
      "src": "/(.*)",
      "dest": "/index"
    }
  ]
}